setForwardHeld = function(shouldHold)
    if isHoldingForward == shouldHold then
        return
    end

    isHoldingForward = shouldHold

    pcall(function()
        VirtualInputManager:SendKeyEvent(shouldHold, Enum.KeyCode.W, false, game)
    end)
end

setBackwardHeld = function(shouldHold)
    if isHoldingBackward == shouldHold then
        return
    end

    isHoldingBackward = shouldHold

    pcall(function()
        VirtualInputManager:SendKeyEvent(shouldHold, Enum.KeyCode.S, false, game)
    end)
end

setHorizontalHeld = function(keyCode)
    if heldHorizontalKey == keyCode then
        return
    end

    if heldHorizontalKey then
        local keyToRelease = heldHorizontalKey
        heldHorizontalKey = nil
        pcall(function()
            VirtualInputManager:SendKeyEvent(false, keyToRelease, false, game)
        end)
    end

    heldHorizontalKey = keyCode
    if keyCode then
        pcall(function()
            VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
        end)
    end
end

stopStrafing = function()
    strafeEndTime = 0
    setHorizontalHeld(nil)
    isStrafing = false
end

local function updateCloseRangeMovement(distance)
    if not distance or distance == math.huge then
        setForwardHeld(false)
        setBackwardHeld(false)
        setHorizontalHeld(nil)
        stopStrafing()
        isBackingOff = false
        return
    end

    if distance < Config.backoffDistance then
        isBackingOff = true
        isStrafing = false
        setForwardHeld(false)
        setBackwardHeld(true)
        setHorizontalHeld(nil)
        stopStrafing()
    elseif distance <= Config.strafeExitDistance then
        isBackingOff = false
        isStrafing = true
        setForwardHeld(false)
        setBackwardHeld(false)
        local now = tick()
        if now >= strafeEndTime then
            local duration = math.random() * (Config.strafeDurationMax - Config.strafeDurationMin) + Config.strafeDurationMin
            nextStrafeDirection = -nextStrafeDirection
            strafeEndTime = now + duration
        end

        if nextStrafeDirection < 0 then
            setHorizontalHeld(Enum.KeyCode.A)
        else
            setHorizontalHeld(Enum.KeyCode.D)
        end
    else
        isBackingOff = false
        isStrafing = false
        setForwardHeld(true)
        setBackwardHeld(false)
        setHorizontalHeld(nil)
        stopStrafing()
        return
    end
end

local function updateWorldSpaceMovement(targetRoot, distance)
    local localRoot = getCharacterRoot(LOCAL_PLAYER)
    local humanoid = getHumanoid(LOCAL_PLAYER)
    if isManualMovementActive() then
        releaseMovementKeys()
        return
    end

    if not localRoot or not targetRoot or not humanoid or not distance or distance == math.huge then
        stopCharacterMovement()
        return
    end

    local flatOffset = targetRoot.Position - localRoot.Position
    flatOffset = Vector3.new(flatOffset.X, 0, flatOffset.Z)
    if flatOffset.Magnitude <= 0.001 then
        humanoid:Move(Vector3.zero, false)
        return
    end

    local toward = flatOffset.Unit
    local right = Vector3.new(-toward.Z, 0, toward.X)
    local desiredMoveMode = "chase"
    local desiredMoveDirection = toward

    if distance < Config.backoffDistance then
        isBackingOff = true
        isStrafing = false
        desiredMoveMode = "backoff"
        desiredMoveDirection = -toward
    elseif distance <= Config.strafeExitDistance then
        isBackingOff = false
        isStrafing = true
        desiredMoveMode = "strafe"
        local now = tick()
        if now >= strafeEndTime then
            local duration = math.random() * (Config.strafeDurationMax - Config.strafeDurationMin) + Config.strafeDurationMin
            nextStrafeDirection = -nextStrafeDirection
            strafeEndTime = now + duration
        end

        desiredMoveDirection = (nextStrafeDirection < 0) and -right or right
    else
        isBackingOff = false
        isStrafing = false
        desiredMoveMode = "chase"
        desiredMoveDirection = toward
    end

    local now = tick()
    if activeMoveMode ~= desiredMoveMode or now >= nextMoveRefreshTime then
        activeMoveMode = desiredMoveMode
        nextMoveRefreshTime = now + Config.moveRefreshMin + math.random() * (Config.moveRefreshMax - Config.moveRefreshMin)
    end

    activeMoveDirection = activeMoveDirection:Lerp(desiredMoveDirection, Config.moveSmoothing)
    if activeMoveDirection.Magnitude <= 0.001 then
        humanoid:Move(Vector3.zero, false)
        return
    end

    humanoid:Move(activeMoveDirection.Unit, false)
end

