local function updateStatusLabel(isBlocking)
    if isBlocking then
        statusLabel.Text = "Status: Blocking!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    else
        if Config.isEnabled then
            statusLabel.Text = "Status: Active"
            statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        else
            statusLabel.Text = "Status: Idle"
            statusLabel.TextColor3 = Color3.fromRGB(199, 21, 133)
        end
    end
end

local function updateTargetLabel()
    if currentTargetPlayer then
        targetLabel.Text = "Target: " .. currentTargetPlayer.Name
    else
        targetLabel.Text = "Target: None"
    end
end

local function updateDistanceLabel(distance)
    if distance then
        distanceLabel.Text = string.format("Distance: %.1f", distance)
    else
        distanceLabel.Text = "Distance: N/A"
    end
end

local function updateDetectedLabel(text)
    detectedLabel.Text = "Detected: " .. text
end

updateCounterLabel = function(text)
    counterLabel.Text = "Last Counter: " .. text
end

scheduleBlockCounter = function(player, animId, delay)
    local scheduledPlayer = player
    task.spawn(function()
        task.wait(delay)

        if not Config.isEnabled then
            return
        end

        if not scheduledPlayer or not isPlayerAlive(scheduledPlayer) then
            return
        end

        if UserInputService:GetFocusedTextBox() then
            return
        end

        updateCounterLabel(string.format("Block %s @ %.2fs", animId, delay))
        tapLeftClick()
    end)
end

local function findTargetInFront()
    local localRoot = getCharacterRoot(LOCAL_PLAYER)
    if not localRoot then return nil, nil end

    local bestPlayer = nil
    local bestRoot = nil
    local bestDot = Config.lockOnDotThreshold
    local bestDistance = math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LOCAL_PLAYER and isPlayerAlive(player) then
            local targetRoot = getCharacterRoot(player)
            if targetRoot then
                local offset = targetRoot.Position - localRoot.Position
                local distance = offset.Magnitude

                if distance <= Config.radius and distance > 0 then
                    local direction = offset.Unit
                    local facingDot = localRoot.CFrame.LookVector:Dot(direction)

                    if facingDot >= Config.lockOnDotThreshold and (facingDot > bestDot or (facingDot == bestDot and distance < bestDistance)) then
                        bestDot = facingDot
                        bestDistance = distance
                        bestPlayer = player
                        bestRoot = targetRoot
                    end
                end
            end
        end
    end

    return bestPlayer, bestRoot
end

refreshCurrentTarget = function()
    currentTargetPlayer, currentTargetRoot = findTargetInFront()
    updateTargetLabel()
end

if Config.isEnabled then
    refreshCurrentTarget()
    toggleButton.Text = "Disable Fight"
    toggleButton.BackgroundColor3 = Color3.fromRGB(255, 105, 180)
    toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    updateDetectedLabel("None")
else
    toggleButton.Text = "Enable Fight"
    toggleButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    toggleButton.TextColor3 = Color3.fromRGB(255, 105, 180)
    updateDetectedLabel("None")
end
updateStatusLabel(false)

local function toggleFight()
    Config.isEnabled = not Config.isEnabled
    if Config.isEnabled then
        refreshCurrentTarget()
        releaseMovementKeys()
        updateDetectedLabel("None")
        toggleButton.Text = "Disable Fight"
        toggleButton.BackgroundColor3 = Color3.fromRGB(255, 105, 180)
        toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    else
        currentTargetPlayer = nil
        currentTargetRoot = nil
        setForwardHeld(false)
        updateTargetLabel()
        updateDistanceLabel(nil)
        updateDetectedLabel("None")
        toggleButton.Text = "Enable Fight"
        toggleButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        toggleButton.TextColor3 = Color3.fromRGB(255, 105, 180)
    end
    updateStatusLabel(false)
end

toggleButton.MouseButton1Click:Connect(toggleFight)

local function handleAnimation(player, animTrack)
    local animIdRaw
    if animTrack and animTrack.Animation then
        animIdRaw = animTrack.Animation.AnimationId
    end
    local animId = normalizeAnimationId(animIdRaw)

    if not Config.isEnabled or UserInputService:GetFocusedTextBox() or blocking then
        return
    end

    if player ~= currentTargetPlayer then
        return
    end
    local blockCounterDelay = animId and getBlockCounterDelay(animId) or nil
    if blockCounterDelay then
        updateDetectedLabel(getDetectedStyle(animId))
        scheduleBlockCounter(player, animId, blockCounterDelay)
        return
    end
    if animId and SAFE_ANIMATIONS[animId] and not blockCounterDelay then
        return
    end

    local distance = getDistance(player)
    if distance > Config.radius then return end

    local shouldAttack = distance >= 0 and distance <= Config.attackRangeMax
    local shouldBlock = distance >= Config.blockRangeMin and distance <= Config.blockRangeMax
    if not shouldAttack and not shouldBlock then
        return
    end

    blocking = true
    updateStatusLabel(true)

    local randomDelayMs = math.random(Config.blockDelayMin, Config.blockDelayMax)
    local randomDelay = randomDelayMs / 1000
    blockTimeLabel.Text = "Last Block: " .. math.floor(randomDelayMs) .. "ms"

    task.wait(randomDelay)

    if not Config.isEnabled then
        blocking = false
        updateStatusLabel(false)
        return
    end

    if not UserInputService:GetFocusedTextBox() then

        pcall(function()
            if shouldAttack then
                tapLeftClick()
            elseif shouldBlock then
                performBlockSequence(nil, nil)
            end
        end)
    end

    blocking = false
    cooldownBar.Visible = false

    updateStatusLabel(false)
end

local function initializePlayerTracking(player)
    local function onCharacterAdded(character)
        local humanoid = character:WaitForChild("Humanoid")
        local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
        animator.AnimationPlayed:Connect(function(animTrack)
            local ok, err = pcall(function()
                handleAnimation(player, animTrack)
            end)
            if not ok then
            end
        end)
    end

    if player.Character then
        pcall(onCharacterAdded, player.Character)
    end
    player.CharacterAdded:Connect(onCharacterAdded)
end

for _, player in ipairs(Players:GetPlayers()) do
    initializePlayerTracking(player)
end
Players.PlayerAdded:Connect(initializePlayerTracking)

RunService.RenderStepped:Connect(function()
    if isManualMovementActive() then
        releaseMovementKeys()
        updateDistanceLabel(currentTargetPlayer and getDistance(currentTargetPlayer) or nil)
    elseif not Config.isEnabled then
        releaseMovementKeys()
        updateDistanceLabel(nil)
    elseif currentTargetPlayer and not isPlayerAlive(currentTargetPlayer) then
        currentTargetRoot = nil
        releaseMovementKeys()
        updateDistanceLabel(nil)
    elseif currentTargetPlayer then
        currentTargetRoot = getCharacterRoot(currentTargetPlayer)

        if currentTargetRoot then
            updateTargetLabel()
            local distance = getDistance(currentTargetPlayer)
            updateDistanceLabel(distance ~= math.huge and distance or nil)
            updateWorldSpaceMovement(currentTargetRoot, distance)
            if tick() >= faceTargetResumeTime then
                faceTarget(currentTargetRoot)
                if Config.useCameraLock then
                    lockCameraToTarget(currentTargetRoot)
                end
            end
        else
            releaseMovementKeys()
            updateDistanceLabel(nil)
        end
    else
        releaseMovementKeys()
        updateDistanceLabel(nil)
    end

end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.Keyboard then
        if input.KeyCode == Enum.KeyCode.W or input.KeyCode == Enum.KeyCode.A or input.KeyCode == Enum.KeyCode.S or input.KeyCode == Enum.KeyCode.D then
            manualMovementKeysDown[input.KeyCode] = true
        end

        if gameProcessed then return end

        if input.KeyCode == Enum.KeyCode.R then
            mainFrame.Visible = not mainFrame.Visible
        elseif input.KeyCode == Enum.KeyCode.F then
            toggleFight()
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.Keyboard then
        if input.KeyCode == Enum.KeyCode.W or input.KeyCode == Enum.KeyCode.A or input.KeyCode == Enum.KeyCode.S or input.KeyCode == Enum.KeyCode.D then
            manualMovementKeysDown[input.KeyCode] = nil
        end
    end
end)
