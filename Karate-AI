tapLeftClick = function()
    local camera = workspace.CurrentCamera
    local viewportSize = camera and camera.ViewportSize or Vector2.new(1920, 1080)
    local x = math.floor(viewportSize.X * 0.5)
    local y = math.floor(viewportSize.Y * 0.5)

    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
    end)
    pcall(function()
        VirtualUser:Button1Down(Vector2.new(x, y), camera and camera.CFrame or CFrame.new())
    end)

    task.wait(0.08)

    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end)
    pcall(function()
        VirtualUser:Button1Up(Vector2.new(x, y), camera and camera.CFrame or CFrame.new())
    end)
end

local function releaseMovementKeys()
    setForwardHeld(false)
    setBackwardHeld(false)
    setHorizontalHeld(nil)
    stopStrafing()
    activeMoveMode = "idle"
    activeMoveDirection = Vector3.zero
    nextMoveRefreshTime = 0
end

local function isManualMovementActive()
    return next(manualMovementKeysDown) ~= nil
end

local function stopCharacterMovement()
    releaseMovementKeys()

    local humanoid = getHumanoid(LOCAL_PLAYER)
    if humanoid then
        humanoid:Move(Vector3.zero, false)
    end
end

local function flickCharacterAndReturn()
    local localRoot = getCharacterRoot(LOCAL_PLAYER)
    if not localRoot then return end

    local direction = (math.random(0, 1) == 0) and -1 or 1
    localRoot.CFrame = localRoot.CFrame * CFrame.Angles(0, math.rad(180 * direction), 0)
    task.wait(0.03)

    if currentTargetRoot then
        faceTarget(currentTargetRoot)
    else
        localRoot.CFrame = localRoot.CFrame * CFrame.Angles(0, math.rad(-180 * direction), 0)
    end
end

local function performBlockSequence(counterDelay, animId)
    VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
    task.wait(0.1)
    VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
    releaseMovementKeys()
    faceTargetResumeTime = tick() + Config.postBlockFlickPause
    flickCharacterAndReturn()
    local delay = counterDelay or (Config.postBlockCounterDelayMin + math.random() * (Config.postBlockCounterDelayMax - Config.postBlockCounterDelayMin))
    task.wait(delay)
    if not Config.isEnabled then
        return
    end
    if animId then
        updateCounterLabel(string.format("Block %s @ %.2fs", animId, delay))
    else
        updateCounterLabel("PostBlock @ " .. string.format("%.2f", tick()))
    end
    tapLeftClick()
end

