-- helpers
local function normalizeAnimationId(id)
    if not id then return nil end
    local s = tostring(id)
    local m = s:match("id=(%d+)")
    if m then return m end
    return s:match("(%d+)")
end

local function getBlockCounterDelay(animId)
    local value = BLOCK_COUNTER[animId]
    if value == nil then
        return nil
    end

    if value == "random" then
        return 1 + (math.random() * 0.8)
    end

    return value
end

local function getDetectedStyle(animId)
    return BLOCK_COUNTER_STYLE[animId] or "Unknown"
end

